{
  "name": "mcp-link",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "pnpm dev:desktop",
    "dev:web": "pnpm --filter @mcp_link/web dev",
    "dev:frontend": "pnpm --filter @mcp_link/web dev",
    "dev:server": "pnpm build:web && cargo run --manifest-path apps/desktop/src-tauri/Cargo.toml --no-default-features --features server --bin mcp-link-server",
    "dev:desktop": "pnpm --filter @mcp_link/desktop dev:desktop",
    "build": "pnpm build:web && pnpm build:desktop && pnpm build:server",
    "build:web": "pnpm --filter @mcp_link/web build",
    "build:server": "pnpm build:web && cargo build --release --manifest-path apps/desktop/src-tauri/Cargo.toml --no-default-features --features server --bin mcp-link-server",
    "build:desktop": "pnpm --filter @mcp_link/desktop build:desktop",
    "make": "pnpm build:desktop",
    "make:desktop": "pnpm build:desktop",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs --fix",
    "typecheck": "pnpm --filter @mcp_link/web typecheck && pnpm --filter @mcp_link/desktop typecheck && pnpm build:web && cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml --no-default-features --features server --bin mcp-link-server",
    "knip": "knip",
    "test:e2e": "echo \"No desktop e2e suite configured yet\""
  },
  "keywords": [],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amberpepper/mcp-link.git"
  },
  "homepage": "https://github.com/amberpepper/mcp-link#readme",
  "bugs": {
    "url": "https://github.com/amberpepper/mcp-link/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.3",
    "@types/node-fetch": "^2.6.13",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "knip": "^6.15.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "webpack-dev-server@<=5.2.3": ">=5.2.4",
      "@octokit/request-error@>=1.0.0 <5.1.1": ">=5.1.1",
      "@octokit/request@>=1.0.0 <8.4.1": ">=8.4.1",
      "@octokit/plugin-paginate-rest@>=1.0.0 <9.2.2": ">=9.2.2",
      "@hono/node-server@<1.19.14": ">=1.19.14",
      "@modelcontextprotocol/sdk@<1.29.0": ">=1.29.0",
      "@tootallnate/once@<2.0.1": ">=2.0.1",
      "@xmldom/xmldom@<0.8.13": "0.8.13",
      "@eslint/plugin-kit@<0.3.3": ">=0.3.3",
      "ajv@<7.0.0": "6.15.0",
      "ajv@>=7.0.0-alpha.0 <8.20.0": ">=8.20.0",
      "brace-expansion@<2.0.0": "1.1.13",
      "brace-expansion@>=2.0.0 <2.1.1": "2.1.1",
      "diff@>=4.0.0 <4.0.4": ">=4.0.4",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "flatted@<3.4.2": ">=3.4.2",
      "follow-redirects@<=1.15.11": ">=1.16.0",
      "hono@<4.12.18": ">=4.12.18",
      "ip-address@<=10.1.0": ">=10.2.0",
      "jsondiffpatch@<0.7.2": ">=0.7.2",
      "lodash@<4.18.1": ">=4.18.1",
      "anymatch>picomatch": "4.0.4",
      "eslint>minimatch": "9.0.7",
      "fork-ts-checker-webpack-plugin>minimatch": "9.0.7",
      "micromatch>picomatch": "4.0.4",
      "minimatch@<3.1.4": "3.1.5",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@9.0.5": "9.0.7",
      "node-forge@<1.4.0": ">=1.4.0",
      "on-headers@<1.1.0": ">=1.1.0",
      "path-to-regexp@>=8.0.0 <8.4.2": ">=8.4.2",
      "path-to-regexp@0.1.12": "0.1.13",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "picomatch@4.0.3": "4.0.4",
      "readdirp>picomatch": "4.0.4",
      "postcss@<8.5.10": ">=8.5.10",
      "qs@<6.15.2": ">=6.15.2",
      "rollup@>=4.0.0 <4.61.0": ">=4.61.0",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "smol-toml@<1.6.1": ">=1.6.1",
      "tar@<7.5.16": ">=7.5.16",
      "terser-webpack-plugin@<5.6.1": ">=5.6.1",
      "tmp@<0.2.6": ">=0.2.6",
      "turbo@<2.9.14": ">=2.9.14",
      "uuid@<11.1.1": ">=11.1.1",
      "webpack@<5.104.1": ">=5.104.1",
      "react-router@>=7.0.0 <=7.11.0": ">=7.12.0",
      "react-router@>=7.0.0 <7.12.0": ">=7.12.0",
      "preact@>=10.28.0 <10.28.2": ">=10.28.2",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0"
    },
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "fs-xattr",
      "macos-alias"
    ]
  }
}
